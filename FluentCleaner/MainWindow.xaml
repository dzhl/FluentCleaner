<Window
    x:Class="FluentCleaner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FluentCleaner">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native TitleBar:icon + title left, search center, [...] right -->
        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Title="FluentCleaner"
                  Subtitle="{x:Bind InsiderSubtitle}"
                  IsPaneToggleButtonVisible="True"
                  PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>


            <TitleBar.Content>
                <Grid>
                    <!-- Full search -->
                    <AutoSuggestBox x:Name="TitleSearchBox"
                        MinWidth="160"
                        MaxWidth="280"
                        Width="280"
                        VerticalAlignment="Center"
                        PlaceholderText="Search"
                        QueryIcon="Find"
                        TextChanged="TitleSearchBox_TextChanged" />

                    <!-- Compact search icon -->
                    <Button x:Name="SearchIconButton"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Search">

                        <FontIcon Glyph="&#xE721;"
                            FontSize="15" />
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <AutoSuggestBox Width="280"
                                    PlaceholderText="Search…"
                                    QueryIcon="Find"
                                    TextChanged="TitleSearchBox_TextChanged" />
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </TitleBar.Content>

            <TitleBar.RightHeader>
                <Button x:Name="BtnPageActions" Width="32" Height="32" Padding="0"
                        ToolTipService.ToolTip="Page actions">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                    </Button.Resources>
                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                    <Button.Flyout>
                        <MenuFlyout x:Name="PageActionsFlyout"
                                    Placement="BottomEdgeAlignedRight"
                                    Opening="PageActionsFlyout_Opening" />
                    </Button.Flyout>
                </Button>
            </TitleBar.RightHeader>
        </TitleBar>

        <!-- NavView sits below TitleBar; IsTitleBarAutoPaddingEnabled=False avoids double padding -->
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="LeftCompact"
                        IsTitleBarAutoPaddingEnabled="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        CompactPaneLength="48"
                        OpenPaneLength="240"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Cleaner" Content="Cleaner" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA99;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Terminal" Content="Terminal">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE943;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Custom" Content="Custom">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE710;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="NavFrame" />
        </NavigationView>
        <!-- donation prompt; anchored to the [...] button -->
        <TeachingTip x:Name="DonationTip"
                     Target="{x:Bind BtnPageActions}"
                     Title="Enjoying FluentCleaner?"
                     Subtitle="If this app saves you time, consider supporting its development."
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="False">
            <TeachingTip.Content>
                <StackPanel Spacing="6" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="PayPal" Click="DonationTip_PayPal"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Ko-fi" Click="DonationTip_KoFi" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <HyperlinkButton Content="Star on GitHub" Click="DonationTip_Star"
                                         Padding="0" FontSize="12" />
                        <HyperlinkButton Content="Maybe later" Click="DonationTip_Dismiss"
                                         Padding="0" FontSize="12"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </TeachingTip.Content>
        </TeachingTip>
    </Grid>
</Window>