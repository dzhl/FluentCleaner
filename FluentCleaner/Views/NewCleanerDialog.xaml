<ContentDialog
    x:Class="FluentCleaner.Views.NewCleanerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    CornerRadius="8">

    <StackPanel Spacing="4">

        <!-- Type picker -->
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
            <ToggleButton x:Name="btnIni" Content="Winapp2 entry (.ini)"    IsChecked="True" Click="TypeBtn_Click" />
            <ToggleButton x:Name="btnPs1" Content="PowerShell script (.ps1)"               Click="TypeBtn_Click" />
        </StackPanel>

        <!-- Name -->
        <TextBox x:Name="nameBox" Header="Name" PlaceholderText="My Cleaner" Margin="0,0,0,4" />

        <!-- AI generate row (hidden when no API key is configured) -->
        <Grid x:Name="aiRow" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="promptBox"
                     PlaceholderText="Generate with AI - describe what to clean (results may vary)"
                     Margin="0,0,6,0" />
            <Button x:Name="generateBtn" Grid.Column="1" Content="Generate" Click="GenerateBtn_Click" />
        </Grid>

        <!-- Content header: label left, Load template right -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Content" VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <HyperlinkButton Grid.Column="1" Content="Load template"
                             Padding="0" Click="TemplateBtn_Click" />
        </Grid>

        <!-- Content editor -->
        <TextBox x:Name="contentBox"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12"
                 Height="260"
                 IsSpellCheckEnabled="False"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />

    </StackPanel>
</ContentDialog>
