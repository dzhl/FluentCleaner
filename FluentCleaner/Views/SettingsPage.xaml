<Page
    x:Class="FluentCleaner.Views.SettingsPage"
    NavigationCacheMode="Required"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FluentCleaner.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- Update banner;shown only when a newer version is available -->
            <InfoBar x:Name="UpdateBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Error" />

            <!-- Donation banner -->
            <InfoBar x:Name="DonationBanner"
                     IsOpen="True"
                     IsClosable="True"
                     Severity="Warning"
                     Title="FluentCleaner is going open source."
                     Message="Put a lot of work into this — if it helps you and you feel like saying thanks, a donation would really mean a lot. ♥">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <DropDownButton Style="{StaticResource AccentButtonStyle}"
                                        Content="Support the project">
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="Donate via PayPal" Click="Link_Donate" />
                                    <MenuFlyoutItem Text="Donate via Ko-fi"  Click="Link_KoFi" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <Button Content="Maybe later"
                                Click="DonationBanner_Dismiss" />
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,26,32,32" Spacing="22" HorizontalAlignment="Stretch">

            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Appearance -->
            <StackPanel Spacing="10">
                <TextBlock Text="Appearance" FontSize="13" FontWeight="SemiBold" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="App theme" FontWeight="SemiBold" />
                        <TextBlock Text="Choose how FluentCleaner looks on your device."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}"
                              MinWidth="140" VerticalAlignment="Center">
                        <ComboBoxItem Content="System default" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </Grid>
            </Border>
            </StackPanel>

            <!-- Database -->
            <StackPanel Spacing="10">

                <StackPanel Spacing="2">
                    <TextBlock Text="Database" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Text="Choose which entry lists are loaded for scanning and cleaning."
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- ProgressRing shown while downloading -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6">
                        <ProgressRing Width="14" Height="14"
                                      IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                          Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="Downloading…" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <!-- Database list card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">

                    <!-- Winapp2 row -->
                    <StackPanel>
                        <Grid MinHeight="72" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xEA99;" FontSize="18"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Border>

                            <!-- Name + info -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="Winapp2" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.Winapp2Info, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <!-- Update button -->
                            <Button Grid.Column="2"
                                    Content="Update"
                                    Command="{x:Bind ViewModel.DownloadLatestCommand}"
                                    HorizontalAlignment="Right"
                                    Visibility="{x:Bind ViewModel.EnableWinapp2, Mode=OneWay,
                                        Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!-- Toggle -->
                            <ToggleSwitch Grid.Column="3"
                                          IsOn="{x:Bind ViewModel.EnableWinapp2, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" Margin="0,0,-8,0"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                        <!-- ── Winapp3 row ── -->
                        <Grid MinHeight="72" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="OrangeRed" />
                            </Border>

                            <!-- Name + info -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Winapp3" FontWeight="SemiBold" />
                                    <Border Background="OrangeRed" CornerRadius="3"
                                            Padding="4,1" VerticalAlignment="Center">
                                        <TextBlock Text="experimental" FontSize="10"
                                                   Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Bind ViewModel.Winapp3Info, Mode=OneWay}" />
                                    <Run Text="  —  more aggressive entries, use at your own risk."
                                         Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Download (not yet on disk) / Update (already downloaded) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="6">
                                <Button Content="Download"
                                        Command="{x:Bind ViewModel.DownloadWinapp3Command}"
                                        Visibility="{x:Bind ViewModel.Winapp3NotAvailable, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Content="Update"
                                        Command="{x:Bind ViewModel.DownloadWinapp3Command}"
                                        Visibility="{x:Bind ViewModel.Winapp3Available, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <!-- Toggle -->
                            <ToggleSwitch Grid.Column="3"
                                          IsOn="{x:Bind ViewModel.EnableWinapp3, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" Margin="0,0,-8,0"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                        <!-- Winappx row -->
                        <Grid MinHeight="72" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE977;" FontSize="18"
                                          Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                            </Border>

                            <!-- Name + info -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Winappx" FontWeight="SemiBold" />
                                    <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                        <TextBlock Text="bloatware" FontSize="10" Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Bind ViewModel.WinappxInfo, Mode=OneWay}" />
                                    <Run Text="  —  AppX / bloatware entries for the terminal debloater."
                                         Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Download (not yet on disk) / Update (already downloaded) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="6">
                                <Button Content="Download"
                                        Command="{x:Bind ViewModel.DownloadWinappxCommand}"
                                        Visibility="{x:Bind ViewModel.WinappxNotAvailable, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Content="Update"
                                        Command="{x:Bind ViewModel.DownloadWinappxCommand}"
                                        Visibility="{x:Bind ViewModel.WinappxAvailable, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <!-- Toggle -->
                            <ToggleSwitch Grid.Column="3"
                                          IsOn="{x:Bind ViewModel.EnableWinappx, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" Margin="0,0,-8,0"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                        <!--Status / error text -->
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   FontSize="11" Margin="18,8,18,8"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                   TextWrapping="WrapWholeWords"
                                   Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay,
                                       Converter={StaticResource NullToVisibilityConverter}}" />

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                   Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay,
                                       Converter={StaticResource NullToVisibilityConverter}}" />

                        <!-- Custom path row -->
                        <Grid MinHeight="76" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8B7;" FontSize="18"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>

                            <!-- Path input (always visible) -->
                            <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         PlaceholderText="Custom database path (.ini)"
                                         Text="{x:Bind ViewModel.CustomPath, Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"
                                         MinWidth="360" />
                                <Button Grid.Column="1" Content="Browse…"
                                        Click="BrowseButton_Click" />
                            </Grid>

                            <!-- Apply / Remove -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Spacing="8" VerticalAlignment="Center">
                                <Button Content="Apply"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Command="{x:Bind ViewModel.ApplyCustomPathCommand}" />
                                <Button Command="{x:Bind ViewModel.RemoveCustomPathCommand}"
                                        Visibility="{x:Bind ViewModel.IsCustomSource, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTipService.ToolTip="Remove custom database">
                                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Restart notice -->
                <InfoBar IsOpen="{x:Bind ViewModel.RestartRequired, Mode=OneWay}"
                         IsClosable="True" Severity="Warning"
                         Title="Restart required"
                         Message="Please restart FluentCleaner to load the updated database." />

            </StackPanel>

            <!-- Post-clean tasks  -->
            <StackPanel Spacing="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Post-clean tasks" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="One command per line — runs sequentially after every clean pass."
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{x:Bind ViewModel.PostCleanEnabled, Mode=TwoWay}"
                                  OnContent=""
                                  OffContent=""
                                  MinWidth="0"
                                  Margin="12,0,-8,0"
                                  VerticalAlignment="Center" />
                </Grid>

                <!-- just Plain code-style text box;user types one command per line -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox Text="{x:Bind ViewModel.PostCleanCommands, Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             MinHeight="116"
                             IsEnabled="{x:Bind ViewModel.PostCleanEnabled, Mode=OneWay}"
                             TextWrapping="NoWrap"
                             BorderThickness="0"
                             Padding="12"
                             PlaceholderText="cleanmgr.exe /sageset:1&#x0a;cleanmgr.exe /sagerun:1&#x0a;start &quot;&quot; ms-settings:storagesense&#x0a;taskkill /f /im explorer.exe &amp; start explorer.exe" />
                </Border>
            </StackPanel>
            <!-- End post-clean tasks -->

            <!-- History -->
            <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                    <TextBlock Text="History" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Text="Track how much junk accumulates over time."
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Expander HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid Margin="4,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Clean history" FontSize="13" />
                                <TextBlock Text="{x:Bind ViewModel.HistorySummary, Mode=OneWay}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{x:Bind ViewModel.CleanHistoryEnabled, Mode=TwoWay}"
                                          OnContent="" OffContent="" MinWidth="0" />
                        </Grid>
                    </Expander.Header>

                    <!-- history table -->
                    <StackPanel Spacing="0">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.HistoryRows, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HistoryRow">
                                    <Grid Padding="4,8"
                                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Date}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Amount}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Bar}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Items}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="Clear history"
                                Command="{x:Bind ViewModel.ClearHistoryCommand}"
                                Margin="0,12,0,4" />
                    </StackPanel>
                </Expander>
            </StackPanel>
            
                <!-- AI explanations -->
                <StackPanel Spacing="8">
                    <StackPanel Spacing="6">

                        <!-- title + AI badge -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="AI explanations" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                    CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="opt-in" FontSize="10" Foreground="White" />
                            </Border>
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="preview" FontSize="10" Foreground="White" />
                            </Border>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12">
                            <Run>Right-click any entry on the Cleaner page → </Run>
                            <Run FontWeight="SemiBold">Explain with AI.</Run>
                            <Run> Powered by Groq (llama-3.3-70b) — free, no billing. Nothing is sent without your explicit action. Requires your own API key.</Run>
                        </TextBlock>

                        <HyperlinkButton Content="Thoughts? Join the discussion →"
                                         NavigateUri="https://github.com/builtbybel/FluentCleaner/discussions/31"
                                         Padding="0" FontSize="12" />
                    </StackPanel>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="18,14">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE899;" FontSize="18"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Border>

                            <PasswordBox Grid.Column="1"
                                     x:Name="ApiKeyBox"
                                     PlaceholderText="gsk_..."
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     VerticalAlignment="Center" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Spacing="6" VerticalAlignment="Center">
                                <Button Content="Save"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="ApiKeySave_Click" />
                                <Button x:Name="btnTestKey" Content="Test"
                                        Click="ApiKeyTest_Click" />
                            </StackPanel>

                            <HyperlinkButton Grid.Column="3"
                                         Content="Get key"
                                         NavigateUri="https://console.groq.com/keys"
                                         VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- test result -->
                    <TextBlock x:Name="lblApiTestResult"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,6,0,0"
                               Visibility="Collapsed"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- About -->
            <StackPanel Spacing="10">
                <TextBlock Text="About" FontSize="13" FontWeight="SemiBold" />

            <Expander x:Name="AboutExpander"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <Grid Margin="4,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Margin="0,0,12,0">
                            <Image Source="ms-appx:///Assets/AppIconAlt.ico" Stretch="UniformToFill" />
                        </Border>

                        <!-- Name + copyright -->
                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="FluentCleaner" FontWeight="SemiBold" />
                                <Border Visibility="{x:Bind InsiderBadgeVisibility}"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3" Padding="5,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="INSIDER" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="© 2026 A Belim app creation"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <!-- Version -->
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind AppVersion}"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    </Grid>
                </Expander.Header>

                <StackPanel Spacing="2" Margin="0,4,0,8">
                    <HyperlinkButton Content="GitHub"
                                     Click="Link_GitHub"
                                     FontSize="13" />
                    <HyperlinkButton Content="Report an issue"
                                     Click="Link_Issues"
                                     FontSize="13" />
                    <HyperlinkButton Content="App icon by naderi"
                                     Click="Link_IconCredit"
                                     FontSize="13" />
                </StackPanel>
            </Expander>

            <!-- faq below About-->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <HyperlinkButton Content="FAQ"
                                 Click="Link_Faq"
                                 FontSize="13" />
            </StackPanel>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
    </Grid>
</Page>